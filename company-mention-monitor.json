      "id": "3c655dd4-8547-44b3-ac70-ebe491f062b4",
      "name": "checkGeminiResponse"
    },
    {
      "parameters": {
        "jsCode": "const parts = $input.first().json.candidates[0].content.parts;\nconst raw = parts.map(p => p.text || '').join('');\n\n// Strip markdown backticks just in case\nconst cleaned = raw\n  .replace(/```json\\n?/gi, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\n// Extract JSON block\nconst jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  throw new Error(`No JSON object found in Gemini response: ${cleaned.substring(0, 300)}`);\n}\n\nlet parsedOutput;\ntry {\n  parsedOutput = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  throw new Error(`Failed to parse Gemini JSON: ${e.message}`);\n}\n\nconst qualityScore = parsedOutput.quality_score || 0;\nconst qualityReasoning = parsedOutput.quality_reasoning || '';\n\ndelete parsedOutput.quality_score;\ndelete parsedOutput.quality_reasoning;\n\nconst id = $('companyMonitorWebhook').first().json.body.id.trim().replace(/[^0-9a-f-]/gi, '');\n\nreturn [{\n  json: {\n    id: id,\n    mentions_output: parsedOutput,\n    quality_score: qualityScore,\n    quality_reasoning: qualityReasoning\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
