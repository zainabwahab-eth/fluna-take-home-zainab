        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"You are a helpful research assistant for climate tech news.\\nSearch recent news (last 12 months) about {{ $json.body.companyName }} strictly in the context of cleantech, climate tech, or clean energy investment.\\nExtract only the 5 most important and recent mentions.\\nReturn **ONLY** valid JSON — no explanations, no markdown, no code blocks, no backticks, no extra text before or after the JSON.\\nExact schema:\\n{\\n  \\\"companyName\\\": \\\"{{ $json.body.companyName }}\\\",\\n  \\\"searchDate\\\": \\\"Month YYYY\\\",\\n  \\\"totalMentionsFound\\\": integer,\\n  \\\"mentions\\\": [\\n    {\\n      \\\"headline\\\": string,\\n      \\\"date\\\": \\\"Month YYYY or Month DD, YYYY\\\",\\n      \\\"source\\\": string,\\n      \\\"url\\\": string,\\n      \\\"summary\\\": \\\"1-2 sentence summary\\\",\\n      \\\"sentiment\\\": \\\"positive|negative|neutral\\\",\\n      \\\"relevance\\\": \\\"high|medium|low\\\"\\n    }\\n  ],\\n  \\\"overallSentiment\\\": \\\"positive|negative|neutral\\\",\\n  \\\"keyThemes\\\": [\\\"theme1\\\", \\\"theme2\\\"],\\n  \\\"quality_score\\\": integer 0-100,\\n  \\\"quality_reasoning\\\": string\\n}\\nOutput must be complete, valid, parseable JSON only.\"\n    }]\n  }],\n  \"tools\": [{ \"google_search\": {} }],\n  \"generationConfig\": {\n    \"temperature\": 0.1,\n    \"maxOutputTokens\": 8192,\n    \"thinkingConfig\": {\n      \"thinkingBudget\": 0\n    }\n  }\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -752,
        208
      ],
      "id": "bb983a37-5d48-4580-a245-b74751e33221",
