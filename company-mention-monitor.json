      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "9dc7e6df-54fa-4135-93f6-d81c097f0fea",
              "leftValue": "={{ !!$json.candidates?.[0]?.content?.parts?.[0]?.text }}",
              "rightValue": "",
